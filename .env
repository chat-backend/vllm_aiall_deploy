# ================================
#  Ollama PRO+ Independent Project
#  Environment Configuration (V15)
# ================================

# Environment mode
APP_ENV=production

# Application name
APP_NAME=OllamaAiallDeployer

# Domain chính của Gateway (phải trùng với DOMAINS trong config.py)
DOMAIN=api.aiallplatform.com

# Email dùng cho Certbot (phải trùng với EMAIL trong config.py)
EMAIL=openaimanage@gmail.com

# ============================================================
#  API KEY & TOKEN SECRET
# ============================================================
# KHÔNG được set thủ công.
# deploy_main.py sẽ tự sinh API_KEY và TOKEN_SECRET mới mỗi lần deploy.
# App sẽ đọc key thật từ:
#   /etc/ollama/project.conf
#   /etc/ollama/api_key
#
# Để tránh nhầm lẫn, để trống:
API_KEY=
TOKEN_SECRET=
